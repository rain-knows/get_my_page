root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 2
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{js,jsx,ts,tsx,json,yml,yaml,md,css,scss}]
indent_size = 2

[*.java]
indent_size = 4
tab_width = 4

[*.xml]
indent_size = 4

[Makefile]
indent_style = tab
