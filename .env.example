# =========================
# Backend
# =========================
BACKEND_PORT=8080
SPRING_PROFILES_ACTIVE=dev
JWT_SECRET=please_change_to_a_long_random_secret
JWT_EXPIRE_SECONDS=7200

# =========================
# Frontend
# =========================
FRONTEND_PORT=3000
NUXT_PUBLIC_API_BASE_URL=http://localhost:8080/api

# =========================
# Production image placeholders
# =========================
BACKEND_IMAGE=ghcr.io/your-org/blog-backend:latest
FRONTEND_IMAGE=ghcr.io/your-org/blog-frontend:latest
