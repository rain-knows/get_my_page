# =========================
# MySQL
# =========================
MYSQL_ROOT_PASSWORD=root_change_me
MYSQL_DATABASE=blog_db
MYSQL_USER=blog_user
MYSQL_PASSWORD=blog_password
MYSQL_PORT=3306

# =========================
# Redis
# =========================
REDIS_PASSWORD=blog_redis_password
